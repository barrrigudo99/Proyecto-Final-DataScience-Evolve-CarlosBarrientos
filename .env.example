# ─── Copia este archivo como .env y rellena los valores reales ────────────────
# cp .env.example .env

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Necesaria para los embeddings y el LLM del agente RAG
OPENAI_API_KEY=sk-...

# ─── Base de datos ───────────────────────────────────────────────────────────
# Ruta a la base de datos SQLite con los inmuebles procesados
DATABASE_URL=sqlite:///data/processed/inmuebles.db

# ─── ChromaDB ────────────────────────────────────────────────────────────────
# Directorio donde se persiste el índice vectorial
CHROMA_PERSIST_DIR=data/embeddings/chroma

# ─── Scraping ────────────────────────────────────────────────────────────────
# User-Agent para evitar bloqueos en scraping
SCRAPING_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)
# Espera entre peticiones (segundos) para no saturar los servidores
SCRAPING_DELAY_SECONDS=2

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/proyecto.log
